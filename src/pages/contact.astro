---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout
  title="문의 — 간병연구소"
  description="간병연구소 문의 안내"
>
  <Header />
  <main>
    <div class="contact-wrap">
      <div class="eyebrow">Contact</div>
      <h1 class="contact-title">문의</h1>
      <p class="contact-body">
        간병연구소(Caregiverlab) 자료의 인용 또는 저작권 관련 문의는<br />
        아래 이메일로 접수하실 수 있습니다.
      </p>
      <a href="mailto:press@caregiverlab.co.kr" class="email-link">
        press@caregiverlab.co.kr
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.contact-wrap {
  max-width: 480px;
  margin: 0 auto;
  padding: 96px 24px 120px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.contact-title {
  font-family: var(--serif);
  font-weight: 600;
  font-size: 28px;
  color: var(--ink);
}
.contact-body {
  font-size: 15px;
  font-weight: 300;
  line-height: 1.8;
  color: var(--muted);
}
.email-link {
  display: inline-block;
  margin-top: 8px;
  font-family: var(--roman);
  font-size: 20px;
  font-weight: 500;
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 0.15s;
}
.email-link:hover {
  border-bottom-color: var(--accent);
}
</style>
