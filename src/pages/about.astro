---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<BaseLayout
  title="About — 간병연구소"
  description="간병연구소는 보호자가 참고할 수 있는 현장 정보를 정리하는 콘텐츠 아카이브입니다."
>
  <Header />
  <main>

    <!-- Page Header -->
    <div class="page-header">
      <div class="container-prose">
        <div class="eyebrow" style="margin-bottom: 16px;">About CaregiverLab</div>
        <h1 class="page-title">간병의 기준을 만듭니다.</h1>
      </div>
    </div>

    <div class="container-prose" style="padding-top: 56px; padding-bottom: 96px;">

      <!-- ① Mission -->
      <section class="ab-section">
        <div class="ab-label">Mission</div>
        <h2 class="ab-h2">현장 기반의 간병 인사이트를 제공합니다.</h2>
        <div class="ab-body-group">
          <p class="ab-body">
            간병이 필요한 순간, 가족은 수많은 선택을 마주하게 됩니다.
          </p>
          <p class="ab-body">
            어떤 간병인을 선택해야 하는지, 비용은 어느 정도가 적절한지,
            왜 다른지에 대한 기준을 찾기 어렵기 때문입니다.
          </p>
          <p class="ab-body">
            간병연구소는 이용 과정에서 발생하는 실제 비용과
            현장의 운영 경험을 바탕으로 보호자가 참고할 수 있는 정보를 정리합니다.
          </p>
          <p class="ab-body">
            간병을 처음 이용하는 가족도 필요한 정보를 확인하고
            합리적인 선택을 할 수 있도록 현장의 데이터를 기록하고 제공합니다.
          </p>
        </div>
      </section>

      <!-- ② Vision -->
      <section class="ab-section">
        <div class="ab-label">Vision</div>
        <h2 class="ab-h2">간병 현장의 데이터를 기록합니다.</h2>
        <div class="ab-body-group">
          <p class="ab-body">
            간병연구소(Caregiver Lab)는 서울간병인협회의 운영 경험을 바탕으로
            간병 서비스 이용 과정에서 발생하는 현장 데이터를 정리하고 있습니다.
          </p>
          <p class="ab-body">
            간병연구소의 일부 자료는 실제 간병 서비스 운영 과정에서
            축적된 현장 데이터를 바탕으로 작성됩니다.
          </p>
          <p class="ab-body">
            보호자가 참고할 수 있는 정보뿐만 아니라,
            간병 서비스 이용 과정 전반에 대한 실질적인 이해를 돕는
            자료를 제공합니다.
          </p>
        </div>
      </section>

      <!-- ③ What We Do -->
      <section class="ab-section">
        <div class="ab-label">What We Do</div>
        <div class="wwd-list">
          {[
            { num: "01", text: "간병비 관련 현장 정보 제공" },
            { num: "02", text: "전문가 의견 및 현장 사례를 바탕으로 한 참고 자료 제공" },
            { num: "03", text: "간병 이용 과정에서 참고할 수 있는 기준 제공" },
          ].map(w => (
            <div class="wwd-row">
              <span class="wwd-num">{w.num}</span>
              <span class="wwd-text">{w.text}</span>
            </div>
          ))}
        </div>

        <div class="cta-row">
          <a href="/research/" class="btn btn-primary">자료 보기 →</a>
          <a href="/contact/" class="btn btn-ghost">문의하기</a>
        </div>
      </section>

      <!-- ④ Archive -->
      <section class="ab-section" style="border-bottom: none; padding-bottom: 0;">
        <div class="ab-label">Archive · Since 2018</div>
        <div class="ab-archive">
          <div class="ab-archive-left">
            <div class="ab-archive-title">2018년부터 쌓아온 현장 기록</div>
            <p class="ab-archive-body">
              간병연구소의 초기 기록은 서울간병인협회 블로그에 보존되어 있습니다.
              간병일지 양식, 의사소통 가이드, 호스피스 케어 등
              현장에서 직접 쌓아온 실무 기록을 확인할 수 있습니다.
            </p>
          </div>
          <a
            href="https://www.seoulhr.com/blog"
            target="_blank"
            rel="noopener noreferrer"
            class="ab-archive-link"
          >
            아카이브 보기 <span>↗</span>
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.page-header {
  background: var(--cream);
  border-bottom: 1px solid var(--bd);
  padding: 56px 0 44px;
  position: relative;
}
.page-header::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--accent), var(--gold) 55%, transparent);
}
.page-title {
  font-family: var(--serif);
  font-weight: 600;
  font-size: clamp(22px, 3.5vw, 30px);
  color: var(--ink);
  line-height: 1.55;
}

/* ── Sections ── */
.ab-section {
  padding-bottom: 52px;
  margin-bottom: 52px;
  border-bottom: 1px solid var(--bd-light);
}
.ab-label {
  font-family: var(--roman);
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 12px;
}
.ab-h2 {
  font-family: var(--serif);
  font-weight: 600;
  font-size: 18px;
  color: var(--ink);
  margin-bottom: 20px;
  line-height: 1.5;
}
.ab-body-group { display: flex; flex-direction: column; gap: 0; }
.ab-body {
  font-size: 15px;
  font-weight: 300;
  line-height: 1.9;
  color: var(--ink-2);
  margin-bottom: 1em;
  max-width: 520px;
}
.ab-body:last-child { margin-bottom: 0; }
.ab-body--lead {
  font-family: var(--serif);
  font-size: 18px;
  font-weight: 600;
  color: var(--ink);
  line-height: 1.65;
}
.ab-body--note {
  font-size: 13px;
  color: var(--subtle);
  padding-left: 14px;
  border-left: 2px solid var(--bd);
  line-height: 1.75;
}

/* ── What We Do ── */
.wwd-list {
  display: flex;
  flex-direction: column;
  border: 1px solid var(--bd);
  border-radius: var(--r);
  overflow: hidden;
  margin-bottom: 28px;
}
.wwd-row {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 16px 20px;
  border-bottom: 1px solid var(--bd);
  transition: background 0.13s;
}
.wwd-row:last-child { border-bottom: none; }
.wwd-row:hover { background: var(--cream); }
.wwd-num {
  font-family: var(--roman);
  font-size: 12px;
  letter-spacing: 0.1em;
  color: var(--gold);
  min-width: 24px;
}
.wwd-text {
  font-family: var(--serif);
  font-size: 15px;
  font-weight: 600;
  color: var(--ink);
}
.cta-row { display: flex; gap: 10px; flex-wrap: wrap; }

/* ── Archive ── */
.ab-archive {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 24px 28px;
  background: var(--ink);
  border-radius: var(--r);
  margin-top: 4px;
}
.ab-archive-title {
  font-family: var(--serif);
  font-weight: 600;
  font-size: 15px;
  color: #fff;
  margin-bottom: 8px;
}
.ab-archive-body {
  font-size: 13px;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(255,255,255,0.5);
  max-width: 380px;
}
.ab-archive-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  color: rgba(255,255,255,0.7);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 9px 18px;
  border-radius: var(--r);
  white-space: nowrap;
  flex-shrink: 0;
  text-decoration: none;
  transition: color 0.14s, border-color 0.14s;
}
.ab-archive-link:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

@media (max-width: 560px) {
  .ab-archive { flex-direction: column; align-items: flex-start; gap: 16px; }
}
</style>
